# =============================================================================
# 3xui-dashboard configuration
# =============================================================================
# Copy this file to .env (alongside the binary or pointed at via the `-env`
# flag) and edit values for your deployment. Real environment variables always
# override values in this file. Lines starting with `#` are comments.

# ---- Runtime ----------------------------------------------------------------
# "dev" enables text logs by default; "prod" enables JSON logs and gin release
# mode. Override LOG_FORMAT explicitly to force one or the other.
ENV=prod

# Address the HTTP server binds to. Use ":8080" for all interfaces or
# "127.0.0.1:8080" to only listen locally (e.g. behind a reverse proxy).
LISTEN_ADDR=:8080

# Per-request timeouts and graceful shutdown deadline.
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
SHUTDOWN_TIMEOUT=20s

# Structured logging. LOG_FORMAT defaults to "text" when ENV=dev else "json".
LOG_LEVEL=info
# LOG_FORMAT=json

# ---- Database (PostgreSQL) --------------------------------------------------
# REQUIRED. Full DSN. Example for docker-compose:
#   postgres://dashboard:dashboard@db:5432/dashboard?sslmode=disable
DATABASE_URL=

# Connection pool sizing.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Apply versioned SQL migrations on startup. Set to false in environments
# where migrations are run by a separate job.
DB_MIGRATE_ON_BOOT=true

# ---- Auth & sessions --------------------------------------------------------
# REQUIRED. Long random string (>=32 bytes recommended) used to sign JWTs for
# both the admin console and the user portal. Rotate by re-issuing tokens.
JWT_SECRET=

# How long an issued access token stays valid.
ACCESS_TOKEN_TTL=24h

# ---- Admin credentials ------------------------------------------------------
# REQUIRED. The single bootstrap administrator. Compared with constant-time
# comparison against the inbound login. Change the password and restart to
# rotate.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---- OIDC (optional) --------------------------------------------------------
# Leave all four blank to disable OIDC login on the user portal. If any of
# OIDC_ISSUER, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET, OIDC_REDIRECT_URL is set
# they must ALL be set or startup fails.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=
OIDC_SCOPES=openid,profile,email

# Optional explicit endpoints — bypass /.well-known/openid-configuration
# discovery when set.
# OIDC_AUTH_URL=
# OIDC_TOKEN_URL=
# OIDC_JWKS_URL=
# OIDC_USERINFO_URL=

# ---- SMTP (optional) --------------------------------------------------------
# Leave SMTP_HOST and SMTP_FROM blank to disable outbound mail (email-binding
# verification flow degrades to "unverified" state).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ---- User registration ------------------------------------------------------
# When false, the public /api/user/auth/register endpoint is rejected (existing
# users can still log in). When true, anyone with the URL can sign up — narrow
# this with EMAIL_DOMAIN_ALLOWLIST.
PUBLIC_REGISTRATION=false

# Comma-separated list of email domains permitted to register, bind, or sign in
# via OIDC. Empty = no domain restriction. Match is case-insensitive on the
# trailing @<domain> portion.
# Example: EMAIL_DOMAIN_ALLOWLIST=example.com,partner.io
EMAIL_DOMAIN_ALLOWLIST=

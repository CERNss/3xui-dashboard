# --- Go ---
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/.cache/
/3xui-dashboard
/backend/bin/
/backend/data/
/backend/tmp/
# Stray `go build ./cmd/dashboard` artifact (the binary lands in
# backend/ if -o isn't passed). Don't track.
/backend/dashboard
# Embedded frontend build output produced into backend/internal/web/dist
# (keep the directory + .gitkeep so go:embed compiles even before a build)
/backend/internal/web/dist/*
!/backend/internal/web/dist/.gitkeep

# --- Node / Vue ---
node_modules/
.npm/
.pnpm-store/
/frontend/dist/
*.tsbuildinfo
# vue-tsc -b emits these from vite.config.ts even with noEmit; keep them out.
/frontend/vite.config.js
/frontend/vite.config.d.ts

# --- Env / secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Editor / OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Claude Code per-user settings (commands/ and skills/ are team-shared) ---
.claude/settings.local.json
.claude/memory/

# --- Agent tooling (skill definitions imported by openspec-* commands) ---
# Skill bundles live at the operator's home dir, not in this project.
.agents/

# --- Logs ---
*.log
logs/

# --- Test coverage ---
coverage/
*.cover
*.coverprofile

# --- Browser / Playwright test artifacts ---
.playwright-mcp/
playwright-report/
blob-report/
test-results/
/frontend/playwright-report/
/frontend/blob-report/
/frontend/test-results/

# --- Runtime uploads ---
uploads/
/backend/uploads/

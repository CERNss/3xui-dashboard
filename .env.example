# 3xui-dashboard — environment configuration template.
#
# Copy to `.env` (which is gitignored) and fill in your values.
# Every variable below has a sensible default OR is documented as
# optional; only the REQUIRED block at the top has no defaults.
#
# Source of truth: internal/config/config.go.

# =============================================================================
# REQUIRED
# =============================================================================

# Postgres connection string. The dashboard auto-runs migrations on boot
# unless DB_MIGRATE_ON_BOOT=false (see below).
DATABASE_URL=postgres://USER:PASS@127.0.0.1:5432/dashboard?sslmode=disable

# JWT signing secret. At least 32 chars; rotate by setting a new value +
# restarting (in-flight tokens invalidate). Don't share between deployments.
JWT_SECRET=change-me-to-a-32-plus-char-random-string

# =============================================================================
# CORE — admin + server
# =============================================================================

# `dev` enables Gin debug logging + text-format slog. `prod` is the default.
ENV=prod

# Where the HTTP server binds.
LISTEN_ADDR=:8080

# Admin login. If ADMIN_PASSWORD is empty, a random one is generated and
# printed to stderr on first boot — convenient for fresh installs but save
# the printed value into your .env for restarts.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# CORS. Empty = permissive (echo Origin, no credentials). Comma-separate
# exact origins for closed-set CORS with credentials enabled.
#   ALLOWED_ORIGINS=https://panel.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Other server knobs (defaults shown).
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
SHUTDOWN_TIMEOUT=20s
LOG_LEVEL=info
# LOG_FORMAT defaults to text in dev, json in prod. Override here if needed.
# LOG_FORMAT=json

# =============================================================================
# DATABASE
# =============================================================================

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MIGRATE_ON_BOOT=true

# =============================================================================
# AUTH — JWT + registration
# =============================================================================

ACCESS_TOKEN_TTL=24h

# When true, /api/user/auth/register is public. When false, only an admin
# can create user accounts via the admin API.
PUBLIC_REGISTRATION=false

# Restrict registration to specific email domains. Comma-separated, empty
# = no restriction.
#   EMAIL_DOMAIN_ALLOWLIST=example.com,partner.example.com
EMAIL_DOMAIN_ALLOWLIST=

# =============================================================================
# OIDC — optional single-sign-on
# =============================================================================
# Enable by setting Issuer + ClientID + ClientSecret + RedirectURL.
# Endpoint URLs default to discovery; override here only if your IDP
# doesn't ship a well-known config.

# OIDC_ISSUER=https://accounts.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://panel.example.com/api/user/auth/oidc/callback
# OIDC_SCOPES=openid,profile,email
# OIDC_DISPLAY_NAME=Company SSO
# OIDC_ICON_URL=

# =============================================================================
# SMTP — optional, but required for email verification + email channel
# =============================================================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@example.com
# SMTP_USE_TLS=true

# =============================================================================
# PAYMENT — alipay (当面付)
# =============================================================================
# Enable by setting AppID + PrivateKey + AlipayPublicKey. The dashboard's
# private key signs outbound calls; alipay's platform public key verifies
# inbound notifies. Both are PEM-encoded.
#
# Currency is fixed to CNY by the alipay 当面付 product — there is no
# config for it on this side.

# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Defaults to production. Set to the sandbox URL for staging.
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=https://panel.example.com/api/public/payment/alipay/notify
# ALIPAY_RETURN_URL=

# =============================================================================
# PAYMENT — stripe (Checkout Sessions)
# =============================================================================
# Stripe distinguishes test/live via secret-key prefix — no separate URL.
# Set Currency to your deployment's market (`cny`, `usd`, `eur`, ...).
#
# STRIPE_CURRENCY default is `usd`. CRITICAL: if you operate in a
# different currency, set this — otherwise plan price_cents (e.g. 500
# for a CNY ¥5 plan) gets billed as $5 USD.

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CURRENCY=usd
# STRIPE_SUCCESS_URL=https://panel.example.com/portal/orders?stripe=ok
# STRIPE_CANCEL_URL=https://panel.example.com/portal/plans?stripe=cancel
# STRIPE_SESSION_EXPIRY_MINUTES=30
# STRIPE_ENDPOINT=  # leave empty for production; override for tests

# =============================================================================
# NOTIFY — channel routing
# =============================================================================
# NOTIFY_ROUTES maps event types to channel name lists. Empty = legacy
# behavior (client lifecycle events only routed to email).
#
# Format: `event.type:chan1,chan2;event.type2:chan3`. Whitespace tolerated.
# Channels referenced but unconfigured log a warning at boot.
#
# Example covering ops + customer events:
#   NOTIFY_ROUTES=\
#     node.offline:telegram,discord;\
#     node.recovered:telegram,discord;\
#     order.payment_confirmed:telegram;\
#     order.payment_failed:telegram;\
#     order.payment_expired:telegram;\
#     order.failed:telegram;\
#     client.expired:email;\
#     client.expiring_soon:email;\
#     client.over_limit:email
NOTIFY_ROUTES=

# Fallback "to:" address for email-routed ops events (the per-event
# ones that don't have an inherent per-user recipient). If email is
# routed for any node.* or order.* event and this is empty, those
# emails silently drop — the dashboard logs a warning at boot.
# NOTIFY_OPS_RECIPIENT=ops@example.com

# =============================================================================
# NOTIFY — channel credentials
# =============================================================================

# Telegram: chat @BotFather → create bot → copy token. Add bot to target
# chat → call /getUpdates once to find the chat_id (negative for groups).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Discord: Server settings → Integrations → Webhooks → Copy URL.
# DISCORD_WEBHOOK_URL=

# Feishu / Lark: 群设置 → 群机器人 → 添加机器人 → 自定义机器人 → copy URL.
# FEISHU_WEBHOOK_URL=

# =============================================================================
# WIREGUARD — at-rest peer-key encryption
# =============================================================================
# When set, enables WG features (admin can create wireguard inbounds, peer
# add/remove uses pg_advisory_xact_lock RMW, /sub/wireguard/:subId renders
# .conf bodies). When empty, the dashboard logs "WG_MASTER_KEY not set —
# wireguard features disabled" at boot and the non-WG flows are unaffected.
#
# Generate with:
#   openssl rand -hex 32
#
# Rotation hazard: rotating WG_MASTER_KEY makes every existing wg_peers row
# unreadable (the GCM tag won't verify under the new key). v1 has no
# re-encryption flow — rotate ONLY by force-re-provisioning every WG peer.
# WG_MASTER_KEY=
